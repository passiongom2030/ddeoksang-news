# Google Gemini API (AI 뉴스 분석 — 무료 플랜)
# 발급: https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_api_key_here
# GEMINI_MODEL=gemini-2.5-flash-lite   # (선택) 모델 변경 시

# Anthropic Claude API (레거시 — 미사용)
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Marketaux 뉴스 API (https://www.marketaux.com - 무료 100 req/day)
MARKETAUX_API_TOKEN=your_marketaux_token_here

# Finnhub API (https://finnhub.io - 무료 60 req/min, 보조 소스)
FINNHUB_API_KEY=your_finnhub_api_key_here

# Slack Incoming Webhook (봇이 채널에 메시지를 보내는 전용 주소)
# 발급: https://api.slack.com/apps -> Create New App -> Incoming Webhooks 활성화 -> Add New Webhook
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/XXX/YYY/ZZZ

# Meta Threads API (레거시 - Slack으로 전환하면서 미사용)
# 발급 방법: https://developers.facebook.com/docs/threads/get-started/get-access-tokens-and-permissions
THREADS_ACCESS_TOKEN=your_long_lived_access_token_here
THREADS_USER_ID=your_threads_user_id_here
